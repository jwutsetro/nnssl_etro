    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Preprocess SSL Dataset",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/nnssl/experiment_planning/plan_and_preprocess_entrypoints.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "-d",
                "739",
                "-pl",
                "FixedResEncUNetPlanner",
                "-fpe",
                "DatasetFingerprintExtractor",
                "-npfp",
                "16",
                "--clean",
            ]
        },
        {
            "name": "Python: Train BaseMAETrainer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/nnssl/run/run_training.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "737",
                "3d_fullres",
                "-tr",
                "BaseMAETrainer",
            ]
        },

        {
            "name": "Python: Train DummyMAETrainer",
